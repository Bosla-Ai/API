# Database Connection Strings
ConnectionStrings__CS=Server=localhost;Database=BoslaDb;User Id=sa;Password=YOUR_PASSWORD;MultipleActiveResultSets=True;TrustServerCertificate=True;
ConnectionStrings__ServerConnection=Server=YOUR_SERVER;Database=YOUR_DB;User Id=YOUR_USER;Password=YOUR_PASSWORD;Encrypt=False;MultipleActiveResultSets=True;

# BaseUrls
PipelineApi__BaseUrl=http://localhost:7860/generate-roadmap

# JWT Configuration
JWT__Key=YOUR_JWT_SECRET_KEY_HERE
JWT__Issuer=https://bosla.almiraj.xyz
JWT__Audience=https://bosla.me
JWT__Expires=30
JWT__RefreshTokenLifeTime=7

# Gemini AI
AI__Gemini__ApiKeys__0=YOUR_GEMINI_API_KEY
AI__Gemini__Model=gemini-3.1-flash-lite-preview
AI__Gemini__FallbackModels__0=gemini-3-flash-preview
AI__Gemini__FallbackModels__1=gemini-2.5-flash
AI__Gemini__ApiUrl=https://generativelanguage.googleapis.com/v1beta/models/gemini-3.1-flash-lite-preview:generateContent
AI__Gemini__MaxRequestsPerUserPerDay=5

# Cerebras (Primary LLM — GPT-OSS 120B)
AI__Llm__Provider=cerebras
AI__Llm__ApiKeys__0=YOUR_CEREBRAS_API_KEY
AI__Llm__ApiUrl=https://api.cerebras.ai/v1/chat/completions
AI__Llm__Model=gpt-oss-120b
AI__Llm__ChatModel=gpt-oss-120b
AI__Llm__ReasoningModel=gpt-oss-120b
AI__Llm__ContextMaxMessageLength=8000
AI__Llm__ContextCompactionCharThreshold=30000

# Groq (Fallback LLM — GPT-OSS 120B)
AI__Groq__ApiKeys__0=YOUR_GROQ_API_KEY
AI__Groq__ApiUrl=https://api.groq.com/openai/v1/chat/completions
AI__Groq__Model=openai/gpt-oss-120b

# Mistral (CV Analysis specialist)
AI__Mistral__ApiKeys__0=YOUR_MISTRAL_API_KEY
AI__Mistral__ApiUrl=https://api.mistral.ai/v1/chat/completions
AI__Mistral__Model=mistral-small-2506

# Google OAuth
Authentication__Google__ClientId=YOUR_GOOGLE_CLIENT_ID
Authentication__Google__ClientSecret=YOUR_GOOGLE_CLIENT_SECRET

# GitHub OAuth
Authentication__Github__ClientId=YOUR_GITHUB_CLIENT_ID
Authentication__Github__ClientSecret=YOUR_GITHUB_CLIENT_SECRET

# Adzuna Job Market API
JobMarket__AppId=YOUR_ADZUNA_APP_ID
JobMarket__AppKey=YOUR_ADZUNA_APP_KEY

# StackExchange API (Tech tag popularity)
StackExchange__ApiKey=YOUR_STACKEXCHANGE_API_KEY

